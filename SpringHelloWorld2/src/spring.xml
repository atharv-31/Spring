<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->

   <bean id="employee" class="com.bean.Employee">
   <property name="id" value="11">  </property>
   <property name="name" value="Sachin"></property>
   <property name="salary" value="1233"></property>
   </bean>
   
   <bean id="employee1" class="com.bean.Employee">
   <constructor-arg name="id" value="123"> </constructor-arg>
   <constructor-arg name="name" value="tejas"></constructor-arg>
   <constructor-arg name="salary" value="5678"></constructor-arg>
   </bean>


</beans>